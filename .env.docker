# Database Configuration for Docker
DB_HOST=mysql
DB_NAME=ad_manager
DB_USER=ad_user
DB_PASS=secure_password
DB_PORT=3306

# API URLs
DHCP_API_URL=http://dhcp-api:5001
SHARE_API_URL=http://share-api:5002

# Security
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Application
APP_ENV=production
APP_DEBUG=false