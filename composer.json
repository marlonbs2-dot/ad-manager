{
    "name": "ad-manager/web-app",
    "description": "Sistema Web de Gerenciamento de Usuários e Grupos do Active Directory",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "ext-ldap": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "ext-json": "*",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^1.29",
        "vlucas/phpdotenv": "^5.6",
        "spomky-labs/otphp": "^11.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
