# AD Manager - Configurações de Ambiente
# Copie este arquivo para .env e configure com seus valores

# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ad_manager
DB_USER=ad_manager_user
DB_PASS=senha_segura_aqui

# Configurações de Sessão
SESSION_LIFETIME=7200
SESSION_NAME=ad_manager_session

# Configurações de Segurança
ENCRYPTION_KEY=gere_uma_chave_aleatoria_de_32_caracteres
CSRF_TOKEN_NAME=csrf_token

# Configurações do Active Directory
AD_HOST=seu-servidor-ad.dominio.local
AD_PORT=389
AD_BASE_DN=DC=dominio,DC=local
AD_USERNAME=usuario-servico@dominio.local
AD_PASSWORD=senha-do-usuario-servico
AD_USE_TLS=false
AD_PROTOCOL=ldap

# Grupos de Permissão (DNs separados por ponto e vírgula)
AD_ADMIN_GROUPS=CN=Administradores do Domínio,CN=Users,DC=dominio,DC=local
AD_RESET_PASSWORD_GROUPS=CN=Operadores de Conta,CN=Builtin,DC=dominio,DC=local
AD_MANAGE_GROUPS=CN=Operadores de Conta,CN=Builtin,DC=dominio,DC=local

# Configurações DHCP (Opcional)
DHCP_API_URL=http://localhost:5001
DHCP_API_KEY=chave-secreta-para-api-dhcp

# Configurações de Debug
DEBUG_MODE=false
LOG_LEVEL=INFO

# Configurações de Email (Futuro)
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
MAIL_USERNAME=noreply@exemplo.com
MAIL_PASSWORD=senha-email
MAIL_FROM_NAME=AD Manager